// WifiSecrets.h.example
//
// Copy this file to WifiSecrets.h (same folder) and fill in your real
// networks. WifiSecrets.h is gitignored -- it never gets committed.
#ifndef UJI_M5_WIFISECRETS_H
#define UJI_M5_WIFISECRETS_H

// Networks are tried in order until one connects, except the most recently
// connected one is always tried first (see WifiCommand.h). List one or
// more; set WIFI_NETWORK_COUNT to match the number of rows below.
#define WIFI_NETWORK_COUNT 2
static const WifiNetwork WIFI_NETWORKS[WIFI_NETWORK_COUNT] = {
  { "YourPrimaryNetwork", "YourPassword" },
  { "YourBackupNetwork",  "YourOtherPassword" },
};

#endif // UJI_M5_WIFISECRETS_H
