// LocationSecrets.h.example
//
// Copy this file to LocationSecrets.h (same folder) and fill in your real
// coordinates. LocationSecrets.h is gitignored -- it never gets committed.
// Compile-time, fixed coordinates instead of IP-geolocation: this device
// doesn't move, and it means one less thing that can fail at request time.
//
// Find your coordinates at https://www.latlong.net/ or similar. LOCATION_NAME
// is just a display label for the full "weather" command -- it's not sent
// anywhere, doesn't need to be precise, and can just be a city name.
#ifndef UJI_M5_LOCATIONSECRETS_H
#define UJI_M5_LOCATIONSECRETS_H

#define LOCATION_LAT  "40.7128"
#define LOCATION_LON  "-74.0060"
#define LOCATION_NAME "Your City"

#endif // UJI_M5_LOCATIONSECRETS_H
